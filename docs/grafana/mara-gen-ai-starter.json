          "range": true,
          "refId": "A"
        }
      ],
      "title": "Estimated cost rate (USD/s)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "showPoints": "auto" },

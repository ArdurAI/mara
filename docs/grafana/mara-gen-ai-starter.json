          "range": true,
          "refId": "A"
        }
      ],
      "title": "M2-06 — Completion rate by pipeline (cross-runtime compare)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },

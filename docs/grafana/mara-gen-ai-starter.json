          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "editorMode": "code",
          "expr": "max by (pipeline) (mara_pipeline_fanout_duration_ms_p95)",
